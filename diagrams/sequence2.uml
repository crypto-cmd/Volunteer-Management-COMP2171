@startuml
skinparam maxMessageSize 150
skinparam shadowing false
skinparam roundcorner 10
skinparam participant {
    BackgroundColor White
    BorderColor #2A5D9A
}
skinparam sequence {
    ArrowColor #2A5D9A
    LifeLineBorderColor #2A5D9A
    LifeLineBackgroundColor #EBF4FA
}

actor "Admin" as Admin
participant "VolunteerTimesheetPage\n<<Boundary>>" as UI
participant "VolunteerApiService\n<<Proxy>>" as API
participant "VolunteerService\n<<Controller>>" as Service
participant "VolunteerRepository\n<<Data Access>>" as Repo
database "Supabase\n<<Database>>" as DB

Admin -> UI : Enters new hours & clicks "Save"
activate UI

UI -> API : updateRecord(vId, rId, newHours)
activate API

API -> Service : PUT /api/volunteers/<vId>/records/<rId>
activate Service

Service -> Repo : updateRecord(vId, rId, newHours)
activate Repo

Repo -> DB : UPDATE timesheet_records SET hours_worked = newHours
activate DB
DB --> Repo : Returns Updated Row Data
deactivate DB

Repo --> Service : TimesheetRecord Object
deactivate Repo

Service --> API : API JSON Response
deactivate Service

API --> UI : returns TimesheetRecord
deactivate API

UI -> UI : Updates local records state array
UI -> UI : addToast(...)

UI --> Admin : Displays updated hours & Success Toast
deactivate UI

@enduml