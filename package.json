{
    "scripts": {
        "dev": "concurrently \"bun run --cwd backend dev\" \"bun run --cwd frontend dev\"",
        "dev:backend": "bun run --cwd backend dev",
        "dev:frontend": "bun run --cwd frontend dev",

        "install:all": "bun install --cwd backend && bun install --cwd frontend",
        "install:backend": "bun install --cwd backend",
        "install:frontend": "bun install --cwd frontend",

        "build:frontend": "bun run --cwd frontend build",
        "build:backend:docker": "bun run --cwd backend build:docker"
    },
    "devDependencies": {
        "concurrently": "^9.2.1"
    }
}