@startuml
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam roundcorner 5
skinparam class {
    BackgroundColor White
    ArrowColor #2A5D9A
    BorderColor #2A5D9A
}
/''/
package "Frontend UI (Boundary)" #EBF4FA {
  class App {
    + currentView: string
    + render()
  }

  class EventsPage {
    - events: EventRecord[]
    - requests: EventRequestRecord[]
    - role: string
    + handleCreateNew()
    + handleSave()
    + handleRequestParticipation()
  }

  class VolunteerTimesheetPage {
    - records: TimesheetRecord[]
    - selectedVolunteer: string
    - role: string
    + fetchRecords()
    + handleSaveClick()
  }

  class DataTable <<Component>> {
    + columns: DataTableColumn[]
    + rows: DataTableRow[]
    + render()
  }

  class Modal <<Component>> {
    + isOpen: boolean
    + title: string
    + render()
  }
}

package "Frontend Services (Client Proxies)" #E8F5E9 {
  class EventApiService {
    - baseUrl: string
    + getEvents(): EventRecord[]
    + createEvent(payload): EventRecord
    + requestEventParticipation(eId, vId)
  }

  class VolunteerApiService {
    - baseUrl: string
    + searchVolunteers(query): Volunteer[]
    + getVolunteerRecords(id): Object
    + updateRecord(vId, rId, hours)
  }
}
/''/

package "Models (Entities)" #F3E5F5 {
  class Volunteer {
    + id: string
    + name: string
    + matchesFuzzy(query: string): boolean
  }

  class Event {
    + id: string
    + name: string
    + description: string
    + date: string
    + time: string
    + location: string
    + capacity: number
    + category: string
    + status: string
  }

  class TimesheetRecord {
    + id: number
    + date: string
    + eventId: string
    + eventName: string
    + hoursWorked: number
    + updateHours(hours: number): void
  }

  class EventRequest {
    + id: number
    + eventId: string
    + volunteerId: string
    + status: string
    + requestedAt: string
    + eventName: string
    + volunteerName: string
    + setStatus(status: string): void
  }
}

package "Repositories (Data Access)" #FCE4EC {
  class VolunteerRepository {
    - supabase: SupabaseClient
    + findAllVolunteers(): Volunteer[]
    + findVolunteerById(id: string): Volunteer
    + getRecordsForVolunteer(id: string): TimesheetRecord[]
    + updateRecord(vId: string, rId: number, hours: number): TimesheetRecord
    + getEventRequests(filters: Object): EventRequest[]
    + createEventRequest(vId: string, eId: string): EventRequest
    + updateEventRequestStatus(reqId: number, status: string): EventRequest
  }

  class EventRepository {
    - supabase: SupabaseClient
    + findAll(): Event[]
    + findById(id: string): Event
    + create(event: Event): void
    + update(event: Event): void
    + delete(id: string): void
  }
}

package "Services (Controllers/Logic)" #FFF3E0 {
  class VolunteerService {
    - repo: VolunteerRepository
    + searchVolunteers(query: string): Volunteer[]
    + getVolunteerRecords(id: string): Object
    + updateRecord(vId: string, rId: number, hours: number): TimesheetRecord
    + getEventRequests(filters: Object): EventRequest[]
    + createEventRequest(vId: string, eId: string): EventRequest
    + updateEventRequestStatus(reqId: number, status: string): EventRequest
  }

  class ManageEventsService {
    - eventRepository: EventRepository
    + createEvent(...) : void
    + updateEvent(event: Event): void
    + deleteEvent(id: string): void
    + getEvent(id: string): Event
    + getAllEvents(): Event[]
  }
}

/''/
App -right-> EventsPage : "renders"
App -right-> VolunteerTimesheetPage : "renders"
EventsPage ..> DataTable : "uses"
EventsPage ..> Modal : "uses"
VolunteerTimesheetPage ..> DataTable : "uses"

EventsPage "1" --> "1" EventApiService : "calls"
EventsPage "1" --> "1" VolunteerApiService : "calls"
VolunteerTimesheetPage "1" --> "1" VolunteerApiService : "calls"
/''/

EventApiService ..> ManageEventsService : "<<HTTPS>>"
EventApiService ..> VolunteerService : "<<HTTPS>>"
VolunteerApiService ..> VolunteerService : "<<HTTPS>>"

' Service to Repository Dependencies (Unidirectional)
VolunteerService "1" -left-> "1" VolunteerRepository : "uses"
ManageEventsService "1" -left-> "1" EventRepository : "uses"

' Repository to Model Dependencies
VolunteerRepository ..> Volunteer : "instantiates"
VolunteerRepository ..> TimesheetRecord : "instantiates"
VolunteerRepository ..> EventRequest : "instantiates"
EventRepository ..> Event : "instantiates"

' Model Relationships (Associations)
EventRequest "*" --> "1" Event : "references"
EventRequest "*" --> "1" Volunteer : "references"
TimesheetRecord "*" --> "1" Volunteer : "belongs to"
TimesheetRecord "*" --> "1" Event : "references"

@enduml